{#
  Item View Content Frame

  Renders one frame div per item; the frame id and class depend on filetype
  so filetype-layout.css can size text, image, and video frames differently.
  The metadata columns (last modified / file size) render inside the frame
  for every filetype.

  Note: the anonymous div inside .filetype-content-container is load-bearing —
  the ".filetype-content-container > div" rule in filetype-layout.css must not
  apply directly to #text_frame.
#}
{% set is_textual = filetype.is_html or filetype.is_text or filetype.is_markdown %}
{% set frame_id = 'text_frame' if is_textual else ('movie_frame' if filetype.is_movie else 'thumbnail_frame') %}
{% set frame_class = 'has-text-left filetype-bg item-text-frame' if is_textual else 'thumbnail filetype-bg' %}

<div class="filetype-bg filetype-main-container">

    {% include 'components/breadcrumb.jinja' %}

    {% include 'components/title_display.jinja' %}

    <div class="filetype-content-container">
        <div>
            <div class="{{ frame_class }}" id="{{ frame_id }}">
                {% if is_textual %}
                    <p class="has-text-left">
                        {{ html|safe }}
                    </p>
                {% elif filetype.is_movie %}
                    <div class="has-text-centered">
                        <video class="responsive-video" controls playsinline
                               poster="{{ thumbnail_uri }}" preload="metadata"
                               src="{{ download_uri }}">
                            Your browser does not support the video tag.
                        </video>
                    </div>
                {% elif filetype.is_pdf %}
                    <div class="has-text-centered">
                        <figure class="image">
                            <a href="/resources/javascript/pdfjs/web/viewer.html?file={{ download_uri }}" id="image_link">
                                <img id="display_image" class="responsive-image" src="{{ thumbnail_uri }}"/>
                            </a>
                        </figure>
                    </div>
                {% elif filetype.is_image or filetype.is_dir or filetype.is_link or filetype.is_archive %}
                    <div class="has-text-centered">
                        <figure class="image">
                            <a href="{{ download_uri }}" id="image_link">
                                <img id="display_image" class="responsive-image"
                                     src="{{ download_uri if is_animated else thumbnail_uri }}"/>
                            </a>
                        </figure>
                    </div>
                {% endif %}

                <div class="columns is-multiline item-columns">
                    <div class="column is-one-half item-column-half">
                        <span class="is-size-7"><span class="has-text-weight-bold" id="last_mod_head">Last Modified: </span></span>
                        <span class="is-size-7">{{ lastmod_ds }}</span>
                    </div>
                    <div class="column is-one-half item-column-half">
                        <span class="is-size-7"><span class="has-text-weight-bold" id="file_size_head">File Size: </span></span>
                        <span class="is-size-7">{{ naturalsize(filesize, gnu=True) }}</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
