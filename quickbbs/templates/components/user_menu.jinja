<!-- User Menu Component -->
{% if user.is_authenticated %}
  <div class="navbar-item has-dropdown" id="user-menu-dropdown">
    <a class="navbar-link" id="user-menu-trigger" role="button" aria-haspopup="true" aria-expanded="false">
      <span class="icon-text">
        <span class="icon">
          <i class="fas fa-user"></i>
        </span>
        <span>{{ user.username }}</span>
      </span>
    </a>
    <div class="navbar-dropdown is-boxed is-right">
      {% if user.is_staff %}
        <a class="navbar-item" href="{{ url('admin:index') }}" hx-boost="false">
          <span class="icon-text">
            <span class="icon">
              <i class="fas fa-cog"></i>
            </span>
            <span>Admin Panel</span>
          </span>
        </a>
        <hr class="navbar-divider">
      {% endif %}
      <a class="navbar-item" href="{{ url('account_change_password') }}" hx-boost="false">
        <span class="icon-text">
          <span class="icon">
            <i class="fas fa-key"></i>
          </span>
          <span>Change Password</span>
        </span>
      </a>
      <a class="navbar-item" href="{{ url('mfa_index') }}" hx-boost="false">
        <span class="icon-text">
          <span class="icon">
            <i class="fas fa-shield-alt"></i>
          </span>
          <span>Security &amp; Passkeys</span>
        </span>
      </a>
      <hr class="navbar-divider">
      <button
        onclick="window.location.href='{{ url('toggle_show_duplicates') }}'; return false;"
        class="navbar-item"
        style="width: 100%; text-align: left; background: none; border: none; cursor: pointer; padding: 0.375rem 1rem;">
        <span class="icon-text">
          <span class="icon">
            {# Use context variable instead of database access #}
            {% if show_duplicates %}
              <i class="fas fa-check"></i>
            {% else %}
              <i class="fas fa-square" style="opacity: 0.3;"></i>
            {% endif %}
          </span>
          <span>Show Duplicates</span>
        </span>
      </button>
      <hr class="navbar-divider">
      <form method="post" action="{{ url('account_logout') }}" class="logout-form" hx-boost="false">
        {% csrf_token %}
        <button type="submit" class="navbar-item logout-button">
          <span class="icon-text">
            <span class="icon">
              <i class="fas fa-sign-out-alt"></i>
            </span>
            <span>Logout</span>
          </span>
        </button>
      </form>
    </div>
  </div>
{% else %}
  <div class="navbar-item">
    <div class="buttons">
      <a class="button is-primary" href="{{ url('account_login') }}" hx-boost="false">
        <strong>Login</strong>
      </a>
    </div>
  </div>
{% endif %}

<script>
(function() {
  function initUserMenu() {
    var dropdown = document.getElementById('user-menu-dropdown');
    var trigger = document.getElementById('user-menu-trigger');
    if (!dropdown || !trigger) return;

    // Toggle on click/tap
    trigger.addEventListener('click', function(e) {
      e.stopPropagation();
      var open = dropdown.classList.toggle('is-active');
      trigger.setAttribute('aria-expanded', open ? 'true' : 'false');
    });

    // Close when clicking outside
    document.addEventListener('click', function() {
      dropdown.classList.remove('is-active');
      trigger.setAttribute('aria-expanded', 'false');
    });
  }

  // Re-init after HTMX swaps (navbar is included in every partial)
  document.addEventListener('DOMContentLoaded', initUserMenu);
  document.addEventListener('htmx:afterSwap', initUserMenu);
})();
</script>
